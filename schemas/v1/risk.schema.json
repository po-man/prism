{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Charity Risk Assessment",
  "description": "Schema for a risk assessment of a charity, focusing on reputational, governance, and regulatory dimensions.",
  "type": "object",
  "properties": {
    "analysis_date": {
      "type": "string",
      "format": "date"
    },
    "overall_risk_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "risk_dimensions": {
      "type": "object",
      "properties": {
        "reputational": {
          "type": "object",
          "properties": {
            "flagged": { "type": "boolean" },
            "severity": { "type": ["string", "null"] },
            "summary": { "type": "string" }
          },
          "required": ["flagged", "severity", "summary"]
        },
        "governance_executive": {
          "type": "object",
          "properties": { "flagged": { "type": "boolean" }, "summary": { "type": "string" } },
          "required": ["flagged", "summary"]
        },
        "regulatory": {
          "type": "object",
          "properties": { "flagged": { "type": "boolean" }, "summary": { "type": "string" } },
          "required": ["flagged", "summary"]
        }
      },
      "required": ["reputational", "governance_executive", "regulatory"]
    },
    "key_incidents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": { "year": { "type": "integer" }, "description": { "type": "string" }, "source_url": { "type": "string" }, "reliability": { "type": ["string", "null"], "enum": ["HIGH", null] } },
        "required": ["year", "description", "source_url", "reliability"]
      }
    }
  },
  "required": ["analysis_date", "overall_risk_level", "risk_dimensions", "key_incidents"]
}