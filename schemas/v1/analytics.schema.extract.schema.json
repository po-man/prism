{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Analytics",
  "description": "Schema for the results of the pass/fail audit checklist.",
  "type": "object",
  "properties": {
    "check_items": {
      "type": "array",
      "description": "A list of audit check-item results.",
      "items": {
        "$ref": "#/definitions/checkItem"
      }
    },
    "calculated_metrics": {
      "type": "array",
      "description": "A list of informational metrics derived from the audit.",
      "items": {
        "oneOf": [
          {
            "$ref": "#/definitions/iesMetric"
          },
          {
            "$ref": "#/definitions/calculatedMetric"
          }
        ]
      }
    }
  },
  "required": [
    "check_items",
    "calculated_metrics"
  ],
  "definitions": {
    "source": {
      "type": [
        "object",
        "null"
      ],
      "description": "Provenance of the metric claim, linking back to the source document.",
      "properties": {
        "source_type": {
          "type": "string",
          "description": "[ALLOWED VALUES: 'attached_report']"
        },
        "source_index": {
          "type": [
            "integer"
          ]
        },
        "page_number": {
          "type": [
            "integer"
          ]
        },
        "quote": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "source_type",
        "quote"
      ]
    },
    "checkItem": {
      "type": "object",
      "description": "A single audit check-item result.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique slug for the check-item (e.g., 'check_reserve_cap')."
        },
        "status": {
          "type": "string",
          "description": "The result status of the check. [ALLOWED VALUES: 'pass', 'fail', 'warning', 'bonus', 'not_disclosed', 'n_a']"
        },
        "significance": {
          "type": "string",
          "description": "The priority or importance of the check. [ALLOWED VALUES: 'HIGH', 'MEDIUM', 'LOW']"
        },
        "category": {
          "type": "string",
          "description": "The domain of the audit check. [ALLOWED VALUES: 'Financial Health', 'Governance', 'Impact Awareness', 'Risk Management', 'Transparency']"
        },
        "details": {
          "type": "object",
          "description": "Transparent details about how the result was obtained.",
          "properties": {
            "formula": {
              "type": "string",
              "description": "The generic formula used for the check."
            },
            "calculation": {
              "type": "string",
              "description": "The specific calculation with values for this charity."
            },
            "elaboration": {
              "type": [
                "string",
                "null"
              ]
            },
            "criteria": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "formula",
            "calculation",
            "elaboration",
            "criteria"
          ]
        }
      },
      "required": [
        "id",
        "status",
        "significance",
        "category",
        "details"
      ]
    },
    "calculatedMetric": {
      "type": "object",
      "description": "A single informational metric.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique slug for the metric (e.g., 'cost_per_outcome')."
        },
        "name": {
          "type": "string",
          "description": "Human-readable name for the metric (e.g., 'Cost Per Outcome')."
        },
        "value": {
          "type": [
            "number",
            "string",
            "null",
            "array"
          ],
          "description": "The calculated value of the metric."
        },
        "confidence_tier": {
          "type": "string",
          "description": "The confidence level of the calculated metric. [ALLOWED VALUES: 'HIGH', 'MEDIUM', 'LOW']"
        },
        "confidence_note": {
          "type": "string",
          "description": "An explanation of how the confidence tier was determined."
        },
        "details": {
          "type": "object",
          "description": "Transparent details about how the result was obtained.",
          "properties": {
            "formula": {
              "type": "string"
            },
            "calculation": {
              "type": "string"
            }
          },
          "required": [
            "formula",
            "calculation"
          ]
        }
      },
      "required": [
        "id",
        "name",
        "value",
        "confidence_tier",
        "confidence_note",
        "details"
      ]
    },
    "iesMetric": {
      "type": "object",
      "description": "Schema for the Impact Equivalency Score (IES) metric.",
      "allOf": [
        {
          "$ref": "#/definitions/calculatedMetric"
        }
      ],
      "properties": {
        "id": {
          "const": "impact_equivalency_score"
        },
        "claimed_ies": {
          "type": "integer",
          "description": "The Impact Equivalency Score (IES) calculated without epistemic discounts."
        },
        "evaluated_ies": {
          "type": "integer",
          "description": "The Impact Equivalency Score (IES) calculated with epistemic discounts applied."
        },
        "details": {
          "properties": {
            "breakdown": {
              "type": "array",
              "description": "A detailed breakdown of the IES calculation for each individual impact metric.",
              "items": {
                "type": "object",
                "properties": {
                  "metric_name": {
                    "type": "string"
                  },
                  "outcome": {
                    "type": "object",
                    "properties": {
                      "value": {
                        "type": "number"
                      },
                      "source_quote": {
                        "type": [
                          "string",
                          "null"
                        ]
                      }
                    }
                  },
                  "w_species": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "value": {
                        "type": "number"
                      },
                      "source": {
                        "type": "string"
                      }
                    }
                  },
                  "w_leverage": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string"
                      },
                      "value": {
                        "type": "number"
                      },
                      "source": {
                        "type": "string"
                      }
                    }
                  },
                  "d_evidence": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string"
                      },
                      "value": {
                        "type": "number"
                      },
                      "source": {
                        "type": "string"
                      }
                    }
                  },
                  "claimed_ies_i": {
                    "type": "number",
                    "description": "The claimed IES for this individual metric, before epistemic discounts."
                  },
                  "ies": {
                    "type": "number"
                  },
                  "calculation": {
                    "type": "string"
                  },
                  "source": {
                    "$ref": "#/definitions/source"
                  }
                }
              }
            }
          }
        }
      },
      "required": [
        "id",
        "claimed_ies",
        "evaluated_ies",
        "confidence_tier",
        "confidence_note",
        "details"
      ]
    }
  }
}