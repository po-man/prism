{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Charity Governance and Financials Schema",
  "description": "A schema for validating the structured data extracted from a charity's annual reports, focusing on Hong Kong LSG compliance and financial health.",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "charity_name": { "type": "string" },
        "registration_number": { "type": "string" },
        "financial_year_start": { "type": "string", "format": "date" },
        "financial_year_end": { "type": "string", "format": "date" }
      },
      "required": ["charity_name", "financial_year_end"]
    },
    "financials": {
      "type": "object",
      "properties": {
        "income": {
          "type": "object",
          "properties": {
            "total": { "type": "number", "minimum": 0 },
            "donations": { "type": "number", "minimum": 0 },
            "government_grants": { "type": "number", "minimum": 0 }
          },
          "required": ["total"]
        },
        "expenditure": {
          "type": "object",
          "properties": {
            "total": { "type": "number", "minimum": 0 },
            "program_services": { "type": "number", "minimum": 0 },
            "fundraising": { "type": "number", "minimum": 0 },
            "administration": { "type": "number", "minimum": 0 }
          },
          "required": ["total"]
        },
        "lsg_specific": {
          "type": "object",
          "properties": {
            "lsg_reserve_amount": { "type": "number", "minimum": 0 },
            "provident_fund_reserve": { "type": "number", "minimum": 0 }
          }
        },
        "ratio_inputs": {
          "type": "object",
          "properties": {
            "net_current_assets": { "type": "number", "minimum": 0 },
            "monthly_operating_expenses": { "type": "number", "minimum": 0 }
          }
        }
      },
      "required": ["income", "expenditure"]
    },
    "governance": {
      "type": "object",
      "properties": {
        "board_structure": {
          "type": "object",
          "properties": {
            "size": { "type": "integer", "minimum": 1 },
            "independent_directors_count": { "type": "integer", "minimum": 0 },
            "remuneration_disclosed": { "type": "boolean" }
          }
        },
        "lsg_compliance": {
          "type": "object",
          "properties": {
            "is_lsg_compliant": {
              "type": "boolean",
              "description": "True if reserves are less than 25% of annual operating expenditure."
            }
          }
        }
      }
    },
    "impact": {
      "type": "object",
      "properties": {
        "scale": {
          "type": "object",
          "properties": {
            "beneficiaries_count": { "type": "integer", "minimum": 0 },
            "geographic_scope": {
              "type": "string",
              "enum": ["HK-Wide", "District", "International"]
            }
          }
        },
        "evidence_quality": {
          "type": "string",
          "enum": ["RCT/Meta-Analysis", "Quasi-Experimental", "Pre-Post", "Anecdotal", "None"]
        },
        "transparency": {
          "type": "object",
          "properties": {
            "reports_publicly_available": { "type": "boolean" }
          }
        }
      }
    },
    "audit_trail": {
      "type": "array",
      "items": { "$ref": "#/definitions/source_ref" }
    }
  },
  "required": ["meta", "financials", "governance", "impact", "audit_trail"],
  "definitions": {
    "source_ref": {
      "type": "object",
      "description": "A reference to a source document for traceability.",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the source document (e.g., PDF annual report)."
        },
        "fetched_at": {
          "type": "string",
          "format": "date-time",
          "description": "The ISO 8601 timestamp when the data was retrieved."
        },
        "snippet": {
          "type": "string",
          "description": "The exact text snippet from the source that supports the data point."
        }
      },
      "required": ["url", "fetched_at", "snippet"]
    }
  }
}
